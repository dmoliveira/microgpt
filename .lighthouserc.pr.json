{
  "ci": {
    "collect": {
      "staticDistDir": "docs",
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.65 }],
        "categories:accessibility": ["warn", { "minScore": 0.88 }],
        "categories:best-practices": ["warn", { "minScore": 0.88 }],
        "categories:seo": ["warn", { "minScore": 0.88 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
